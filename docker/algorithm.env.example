# Host CARLA is intentionally not started by docker/compose.algorithm.yml.
ALGORITHM_ID=tcp
ALGORITHM_PLUGIN=tcp_closedloop_plugin:create_backend
ALGORITHM_REPO_HOST_PATH=E:/models/TCP
ALGORITHM_CHECKPOINT_HOST_DIR=E:/models/TCP/checkpoints
ALGORITHM_CHECKPOINT_FILE=best_model.pth
SIM_DATA_HOST_PATH=E:/sim-data

# Linux host networking lets ROS 2 DDS and the plugin reach host services.
ALGORITHM_NETWORK_MODE=host
ROS_DOMAIN_ID=0
CONTROL_TOPIC=/carla/ego_vehicle/vehicle_control_cmd
CARLA_HOST=127.0.0.1
CARLA_PORT=2000
